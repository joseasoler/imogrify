{
	"version": 6,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 25,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "cfg-base",
			"binaryDir": "build/${presetName}",
			"hidden": true,
			"generator": "Ninja",
			"cacheVariables": {
				"CMAKE_COMPILE_WARNING_AS_ERROR": "ON",
				"VCPKG_OVERLAY_PORTS": "${sourceDir}/cmake/custom_vcpkg/ports",
				"VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/custom_vcpkg/triplets",
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
				"IMOGRIFY_BUILD_UNIT_TESTS": "ON",
				"IMOGRIFY_BUILD_MICROBENCHMARKS": "ON",
				"IMOGRIFY_BUILD_CPU_INFORMATION": "ON"
			}
		},
		{
			"name": "cfg-debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			},
			"hidden": true
		},
		{
			"name": "cfg-release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			},
			"hidden": true
		},
		{
			"name": "cfg-arm64-macos",
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Darwin"
			},
			"cacheVariables": {
				"VCPKG_TARGET_TRIPLET": "arm64-osx"
			},
			"hidden": true
		},
		{
			"name": "cfg-x64-linux",
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			},
			"cacheVariables": {
				"IMOGRIFY_CLANG_TIDY": "ON",
				"CMAKE_CXX_FLAGS": "-march=x86-64-v3 -mavx2"
			},
			"hidden": true
		},
		{
			"name": "cfg-x64-linux-gcc",
			"cacheVariables": {
				"VCPKG_TARGET_TRIPLET": "imfy-x64-linux-gcc"
			},
			"inherits": [
				"cfg-x64-linux"
			],
			"hidden": true
		},
		{
			"name": "cfg-x64-linux-clang",
			"cacheVariables": {
				"CMAKE_C_COMPILER": "clang",
				"CMAKE_CXX_COMPILER": "clang++",
				"VCPKG_TARGET_TRIPLET": "imfy-x64-linux-clang"
			},
			"inherits": [
				"cfg-x64-linux"
			],
			"hidden": true
		},
		{
			"name": "cfg-x64-windows",
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			},
			"cacheVariables": {
				"VCPKG_TARGET_TRIPLET": "imfy-x64-windows-msvc",
				"CMAKE_CXX_FLAGS_INIT": "/arch:AVX2"
			},
			"hidden": true
		},
		{
			"name": "cfg-arm64-macos-release-clang",
			"inherits": [
				"cfg-base",
				"cfg-release",
				"cfg-arm64-macos"
			],
			"displayName": "Arm64 MacOS Release Clang configuration"
		},
		{
			"name": "cfg-x64-linux-debug-gcc",
			"inherits": [
				"cfg-base",
				"cfg-debug",
				"cfg-x64-linux-gcc"
			],
			"displayName": "x64 Linux Debug GCC configuration"
		},
		{
			"name": "cfg-x64-linux-release-gcc",
			"inherits": [
				"cfg-base",
				"cfg-release",
				"cfg-x64-linux-gcc"
			],
			"displayName": "x64 Linux Release GCC configuration"
		},
		{
			"name": "cfg-x64-linux-debug-clang",
			"inherits": [
				"cfg-base",
				"cfg-debug",
				"cfg-x64-linux-clang"
			],
			"displayName": "x64 Linux Debug Clang configuration"
		},
		{
			"name": "cfg-x64-linux-release-clang",
			"inherits": [
				"cfg-base",
				"cfg-release",
				"cfg-x64-linux-clang"
			],
			"displayName": "x64 Linux Release Clang configuration"
		},
		{
			"name": "cfg-x64-windows-debug-msvc",
			"inherits": [
				"cfg-base",
				"cfg-debug",
				"cfg-x64-windows"
			],
			"displayName": "x64 Windows MSVC debug configuration",
			"cacheVariables": {
				"CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebug"
			}
		},
		{
			"name": "cfg-x64-windows-release-msvc",
			"inherits": [
				"cfg-base",
				"cfg-release",
				"cfg-x64-windows"
			],
			"displayName": "x64 Windows MSVC release config",
			"cacheVariables": {
				"CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
			}
		}
	],
	"buildPresets": [
		{
			"name": "build-arm64-macos-release-clang",
			"configurePreset": "cfg-arm64-macos-release-clang",
			"displayName": "Arm64 MacOS Release Clang build"
		},
		{
			"name": "build-x64-linux-debug-gcc",
			"configurePreset": "cfg-x64-linux-debug-gcc",
			"displayName": "Linux Debug GCC build"
		},
		{
			"name": "build-x64-linux-release-gcc",
			"configurePreset": "cfg-x64-linux-release-gcc",
			"displayName": "Linux Release GCC build"
		},
		{
			"name": "build-x64-linux-debug-clang",
			"configurePreset": "cfg-x64-linux-debug-clang",
			"displayName": "Linux Debug Clang build"
		},
		{
			"name": "build-x64-linux-release-clang",
			"configurePreset": "cfg-x64-linux-release-clang",
			"displayName": "Linux Release Clang build"
		},
		{
			"name": "build-x64-windows-debug-msvc",
			"configurePreset": "cfg-x64-windows-debug-msvc",
			"displayName": "Windows Debug MSVC build"
		},
		{
			"name": "build-x64-windows-release-msvc",
			"configurePreset": "cfg-x64-windows-release-msvc",
			"displayName": "Windows Release MSVC build"
		}
	],
	"testPresets": [
		{
			"name": "test-arm64-macos-release-clang",
			"configurePreset": "cfg-arm64-macos-release-clang",
			"displayName": "Arm64 MacOS Release Clang tests"
		},
		{
			"name": "test-x64-linux-debug-gcc",
			"configurePreset": "cfg-x64-linux-debug-gcc",
			"displayName": "X64 Linux Debug GCC tests"
		},
		{
			"name": "test-x64-linux-release-gcc",
			"configurePreset": "cfg-x64-linux-release-gcc",
			"displayName": "X64 Linux Release GCC tests"
		},
		{
			"name": "test-x64-linux-debug-clang",
			"configurePreset": "cfg-x64-linux-debug-clang",
			"displayName": "X64 Linux Debug Clang tests"
		},
		{
			"name": "test-x64-linux-release-clang",
			"configurePreset": "cfg-x64-linux-release-clang",
			"displayName": "X64 Linux Release Clang tests"
		},
		{
			"name": "test-x64-windows-debug-msvc",
			"configurePreset": "cfg-x64-windows-debug-msvc",
			"displayName": "X64 Windows Debug MSVC tests"
		},
		{
			"name": "test-x64-windows-release-msvc",
			"configurePreset": "cfg-x64-windows-release-msvc",
			"displayName": "X64 Windows Release MSVC tests"
		}
	]
}