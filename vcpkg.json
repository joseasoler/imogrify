{
	"$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
	"name": "imogrify",
	"version": "0.1.0",
	"builtin-baseline": "d5ec528843d29e3a52d745a64b469f810b2cedbf",
	"dependencies": [
		"fmt",
		"highway",
		"tl-expected"
	],
	"features": {
		"imogrify-benchmark": {
			"description": "Build benchmarks",
			"dependencies": [
				"nanobench",
				"lodepng"
			]
		},
		"imogrify-benchmark-use-zlib": {
			"description": "Build benchmarks with zlib",
			"dependencies": [
				"libspng"
			]
		},
		"imogrify-benchmark-use-zlib-ng": {
			"description": "Build benchmarks with zlib-ng",
			"dependencies": [
				"imfy-libspng-ng"
			]
		},
		"imogrify-cpu-information": {
			"description": "CPU information support",
			"dependencies": [
				"cpuid"
			]
		},
		"imogrify-tests": {
			"description": "Build unit tests",
			"dependencies": [
				"doctest"
			]
		},
		"imogrify-use-zlib": {
			"description": "Build with zlib-ng",
			"dependencies": [
				"libpng",
				"zlib"
			]
		},
		"imogrify-use-zlib-ng": {
			"description": "Build with zlib-ng",
			"dependencies": [
				"imfy-libpng-ng",
				"imfy-zlib-ng"
			]
		}
	}
}