{
	"name": "imogrify",
	"version": "0.1.0",
	"dependencies": [
		"fmt",
		"highway",
		"magic-enum",
		"tl-expected"
	],
	"features": {
		"imogrify-benchmark": {
			"description": "Build benchmarks",
			"dependencies": [
				"nanobench",
				"lodepng"
			]
		},
		"imogrify-benchmark-use-zlib": {
			"description": "Build benchmarks with zlib",
			"dependencies": [
				"libspng"
			]
		},
		"imogrify-benchmark-use-zlib-ng": {
			"description": "Build benchmarks with zlib-ng",
			"dependencies": [
				"imfy-libspng-ng"
			]
		},
		"imogrify-cpu-information": {
			"description": "CPU information support",
			"dependencies": [
				"cpuid"
			]
		},
		"imogrify-tests": {
			"description": "Build unit tests",
			"dependencies": [
				"doctest"
			]
		},
		"imogrify-use-zlib": {
			"description": "Build with zlib-ng",
			"dependencies": [
				"libpng",
				"zlib"
			]
		},
		"imogrify-use-zlib-ng": {
			"description": "Build with zlib-ng",
			"dependencies": [
				"imfy-libpng-ng",
				"imfy-zlib-ng"
			]
		}
	}
}